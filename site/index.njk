---
layout: base
css: home.css
---
<section class="hero">
  <div class="hero-text">
    <h1>Hey y'all<span class="accent">,</span><br>I'm Mike Cravey.</h1>
    <p>Father, husband, teacher, and geek</p>
    <div class="hero-links">
      {%- for contact in metadata.author.contacts %}
      <a href="{{ contact.url }}">{{ contact.name }} &rarr;</a>
      {%- endfor %}
    </div>
  </div>
  <div class="hero-portrait">
    <picture>
      <source
        type="image/avif"
        srcset="/img/hero/portrait-1x.avif 1x, /img/hero/portrait-2x.avif 2x">
      <source
        type="image/webp"
        srcset="/img/hero/portrait-1x.webp 1x, /img/hero/portrait-2x.webp 2x">
      <img
        src="/img/hero/portrait-1x.jpg"
        srcset="/img/hero/portrait-1x.jpg 1x, /img/hero/portrait-2x.jpg 2x"
        alt="Mike Cravey"
        width="280"
        height="340">
    </picture>
  </div>
  {# Mobile Option C layout (shown via CSS) #}
  <div class="hero-top">
    <div class="hero-avatar">
      <picture>
        <source
          type="image/avif"
          srcset="/img/hero/avatar-1x.avif 1x, /img/hero/avatar-2x.avif 2x">
        <source
          type="image/webp"
          srcset="/img/hero/avatar-1x.webp 1x, /img/hero/avatar-2x.webp 2x">
        <img
          src="/img/hero/avatar-1x.jpg"
          srcset="/img/hero/avatar-1x.jpg 1x, /img/hero/avatar-2x.jpg 2x"
          alt="Mike Cravey"
          width="72"
          height="72">
      </picture>
    </div>
    <div>
      <div class="hero-name">Hey y'all<span class="accent">,</span><br>I'm Mike Cravey.</div>
      <div class="hero-tagline">UX Engineer</div>
    </div>
  </div>
</section>

{% include "partials/divider.njk" %}

<section class="section-grid about">
  <div class="section-label">About</div>
  <div class="about-content">
    <p>I'm a UX Engineer currently looking for my next opportunity. I like to tinker with my <a href="https://github.com/craveytrain/dotfiles">dotfiles</a>, try out new tools and sometimes I even build things.</p>
    <p>After spending years in Austin and a year abroad (ask me about my time in London), my family and I now live back in small town Texas where my wife and I grew up. You can usually find me scouting out decent coffee or food.</p>
    <p>You can see what I'm up to <a href="/now/">now</a>, read more about how this site is made on the <a href="/colophon/">colophon</a>, or see what tools I use on the <a href="/uses/">uses</a> page.</p>
  </div>
</section>

{% include "partials/divider.njk" %}

<section class="section-grid posts">
  <div class="section-label">Latest Posts</div>
  <div class="post-list">
    {%- set recentPosts = collections.post | reverse | head(3) %}
    {%- for post in recentPosts %}
    <div class="post-item">
      <div class="post-date">{{ post.date | monthYear }}</div>
      <div>
        <h3><a href="{{ post.url }}">{{ post.data.title }}</a></h3>
        {%- if post.data.description %}
        <p class="post-excerpt">{{ post.data.description }}</p>
        {%- endif %}
        {%- if post.data.tags %}
        <div class="post-tags">
          {%- for tag in post.data.tags | contentTags %}
          <a href="/tags/{{ tag | slugify }}/" class="tag-chip">{{ tag }}</a>
          {%- endfor %}
        </div>
        {%- endif %}
      </div>
    </div>
    {%- endfor %}
    <a href="/posts/" class="section-link">View all posts &rarr;</a>
  </div>
</section>
