{%- if posts.length -%}
{% for group in posts | groupByYearDesc %}
  <section class="section-grid year-group">
    <div class="section-label">{{ group.year }}</div>
    <div class="posts-for-year">
      {% for post in group.posts %}
        <article class="post-item">
          <div class="post-meta-left">
            <h2 class="post-title">
              <a href="{{ post.url }}">{{ post.data.title }}</a>
            </h2>
            {%- if post.data.contentTags.length > 0 -%}
            <span class="post-tags-inline">
              {{ post.data.contentTags | join(", ") }}
            </span>
            {%- endif -%}
          </div>
          <time class="post-date" datetime="{{ post.date | htmlDateString }}">
            {{ post.date | monthYear }}
          </time>
        </article>
      {% endfor %}
    </div>
  </section>

  {% if not loop.last %}
    {% include "partials/divider.njk" %}
  {% endif %}
{% endfor %}
{%- endif -%}
